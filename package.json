{
  "name": "@bigtablet/create-frontend",
  "publishConfig": {
    "access": "public"
  },
  "version": "1.2.0",
  "type": "module",
  "description": "Bigtablet Next.js frontend template",
  "bin": {
    "create-bigtablet-frontend": "bin/create-bigtablet-frontend.js"
  },
  "files": [
    "bin",
    "templates"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/core": "^20.5.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@types/node": "^25",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "husky": "^9.1.7",
    "semantic-release": "^25.0.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  },
  "packageManager": "pnpm@10.32.0",
  "license": "MIT",
  "pnpm": {
    "overrides": {
      "handlebars": ">=4.7.9",
      "lodash": ">=4.18.0",
      "lodash-es": ">=4.18.0",
      "undici": ">=7.24.0",
      "picomatch": ">=4.0.4"
    }
  }
}
